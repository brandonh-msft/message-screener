{
  "servers": {
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_TOKEN": "${env:MESSAGE_SCREENER_GITHUB_TOKEN}"
      }
    },
    "workiq": {
      "command": "copilot",
      "args": [
        "mcp",
        "serve",
        "workiq"
      ]
    },
    "microsoft-learn": {
      "command": "npx",
      "args": [
        "-y",
        "@microsoft/microsoft-learn-mcp"
      ]
    }
  }
}
