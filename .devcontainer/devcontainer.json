{
  "name": "message-screener-dev",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false,
      "username": "vscode"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/copilot-cli:1": {},
    "ghcr.io/devcontainers/features/azure-cli:1": {},
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    },
    "ghcr.io/devcontainers/features/powershell:1": {}
  },
  "mounts": [
    "source=${localWorkspaceFolder}/.devcontainer/gitconfig.effective,target=/workspaces/${localWorkspaceFolderBasename}/.devcontainer/gitconfig.effective,type=bind,consistency=cached"
  ],
  "containerEnv": {
    "POWERSHELL_DISTRIBUTION_CHANNEL": "DevContainers"
  },
  "postCreateCommand": "bash .devcontainer/scripts/bootstrap-copilot-digital-twin.sh",
  "postStartCommand": "bash .devcontainer/scripts/apply-global-git-config.sh .devcontainer/gitconfig.effective",
  "customizations": {
    "vscode": {
      "settings": {
        "dotnet.defaultSolution": "MessageScreener.slnx",
        "terminal.integrated.defaultProfile.linux": "pwsh"
      },
      "extensions": [
        "ms-dotnettools.csharp",
        "ms-azuretools.vscode-azureresourcegroups",
        "ms-azuretools.vscode-bicep",
        "github.copilot",
        "github.copilot-chat"
      ]
    }
  }
}
