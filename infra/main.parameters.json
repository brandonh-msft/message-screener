{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
      "environmentName": {
        "value": "${AZURE_ENV_NAME}"
      },
      "location": {
        "value": "${AZURE_LOCATION}"
      },
      "messagescreenerApiExists": {
        "value": "${SERVICE_MESSAGESCREENER_API_RESOURCE_EXISTS=false}"
      },
      "teamsAppId": {
        "value": "${MESSAGE_SCREENER_TEAMS_APP_ID=}"
      },
      "personalReviewConversationId": {
        "value": "${MESSAGE_SCREENER_PERSONAL_REVIEW_CONVERSATION_ID=}"
      }
    }
}
