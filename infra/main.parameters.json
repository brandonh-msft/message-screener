{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
      "environmentName": {
        "value": "${AZURE_ENV_NAME}"
      },
      "location": {
        "value": "${AZURE_LOCATION}"
      },
      "messagescreenerApiExists": {
        "value": "${SERVICE_MESSAGESCREENER_API_RESOURCE_EXISTS=false}"
      },
      "teamsAppId": {
        "value": "${MESSAGE_SCREENER_TEAMS_APP_ID=}"
      },
      "personalReviewConversationId": {
        "value": "${MESSAGE_SCREENER_PERSONAL_REVIEW_CONVERSATION_ID=}"
      },
      "githubCopilotToken": {
        "value": "${MESSAGE_SCREENER_GITHUB_TOKEN=}"
      },
      "m365ClientId": {
        "value": "${MESSAGE_SCREENER_M365_CLIENT_ID=}"
      },
      "m365ClientSecret": {
        "value": "${MESSAGE_SCREENER_M365_CLIENT_SECRET=}"
      },
      "m365TenantId": {
        "value": "${MESSAGE_SCREENER_M365_TENANT_ID=}"
      },
      "copilotModel": {
        "value": "${MESSAGE_SCREENER_COPILOT_MODEL=}"
      },
      "copilotAgent": {
        "value": "${MESSAGE_SCREENER_COPILOT_AGENT=message-screener-researcher}"
      }
    }
}
